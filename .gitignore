# ============================================
# PYTHON
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
*.egg

# ============================================
# ENTORNO VIRTUAL
# ============================================
venv/
env/
.venv/
.env

# ============================================
# MEMORIA VECTORIAL (CHROMA DB)
# ============================================
memory/chroma_db/
memory_db/

# ============================================
# BASES DE DATOS
# ============================================
*.db
*.sqlite
*.sqlite3

# ============================================
# LOGS
# ============================================
logs/
*.log

# ============================================
# PROYECTOS (PROYECTOS GENERADOS TEMPORALES)
# ============================================
projects/
workspace/

# ============================================
# IDE Y EDITORES
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.bak

# ============================================
# PROYECTOS GENERADOS (OPCIONAL)
# ============================================
# Descomenta la siguiente línea si NO quieres versionar los proyectos generados
# projects/*/
# Mantén el .gitkeep para preservar la carpeta vacía
!projects/.gitkeep

# ============================================
# ARCHIVOS DE CONFIGURACIÓN SENSIBLES
# ============================================
*.pem
*.key
*.crt
credentials.json
service-account.json

# ============================================
# OTROS
# ============================================
.coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.pyc
*.pyo
nfrontend/frontend/node_modules/